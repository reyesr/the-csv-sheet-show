{
	"compilerOptions": {
		"target": "ES2022",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"types": [
			"vite/client"
		],
		"isolatedModules": true,
		"noEmit": true
	},
	"include": [
		"src",
		"../src/shared"
	]
}
