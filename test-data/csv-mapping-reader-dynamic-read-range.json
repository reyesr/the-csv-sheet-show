{
    "row-count": 100000,
    "column-count": 5,
    "encoding": "utf-8",
    "line-ending": "LF",
    "cell-separator": ",",
    "has-header": false,
    "decimal-separator": ".",
    "special-rows": {
        "0": ["row-0", "alpha", "first row", "0", "0.00"],
        "1": ["row-1", "bravo", "second row", "1", "1.01"],
        "999": ["row-999", "quoted", "contains,comma", "999", "99.99"],
        "50000": ["row-50000", "middle", "contains \"quote\"", "50000", "50.50"],
        "99999": ["row-99999", "omega", "last row", "99999", "9.99"]
    },
    "page-assertions": [
        { "offset": 0, "row-count": 3 },
        { "offset": 997, "row-count": 5 },
        { "offset": 49998, "row-count": 5 },
        { "offset": 99997, "row-count": 10 }
    ]
}
